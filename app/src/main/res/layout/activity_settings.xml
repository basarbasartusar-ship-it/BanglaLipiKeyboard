<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:title="@string/app_name" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Enable keyboard CTA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/setup_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/setup_description"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnableKeyboard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/enable_keyboard" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSwitchKeyboard"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/switch_keyboard" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Theme -->
            <TextView
                style="@style/SectionHeader"
                android:text="@string/section_theme" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/themeToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeLight"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/theme_light" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeDark"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/theme_dark" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeAmoled"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/theme_amoled" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Typing behavior -->
            <TextView
                style="@style/SectionHeader"
                android:text="@string/section_typing" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAutoCap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_capitalize" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDoubleSpace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/double_space_period" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/word_suggestions" />

            <!-- Feedback -->
            <TextView
                style="@style/SectionHeader"
                android:text="@string/section_feedback" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchSound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/key_sound" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchHaptic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/key_haptic" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchPopup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/key_popup" />

            <!-- Layout -->
            <TextView
                style="@style/SectionHeader"
                android:text="@string/section_layout" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchOneHanded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/one_handed_mode" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/keyboard_height" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderHeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="80"
                android:valueTo="130"
                android:stepSize="5" />

            <!-- Personal dictionary -->
            <TextView
                style="@style/SectionHeader"
                android:text="@string/section_dictionary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportDictionary"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/export_dictionary" />

            <TextView
                android:id="@+id/txtDictionaryCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
